# ─── PostgreSQL（复用旧项目数据库）─────────────────────────────────────
POSTGRES_HOST=192.168.21.39
POSTGRES_PORT=5433
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=stocks_data

# ─── 强势股池 API ──────────────────────────────────────────────────────
# 智兔 / 魔码云服（两者选一，或都填用于切换）
# 填写实际 API 地址和 Key 后，将 STRONG_POOL_SOURCE 改为对应来源

ZHITU_API_URL=https://api.zhitu.com
ZHITU_API_KEY=your_key_here

MOMA_API_URL=https://api.moma.com
MOMA_API_KEY=your_key_here

# 默认使用哪个强势股池来源: zhitu | moma | local
# 下载历史数据时需设置为 zhitu 或 moma
STRONG_POOL_SOURCE=local

# ─── 项目路径 ─────────────────────────────────────────────────────────
# 强势股池本地快照目录（CSV格式，用于离线回测）
STRONG_POOL_SNAPSHOT_DIR=data/strong_pool_snapshots

# ─── 下载配置 ─────────────────────────────────────────────────────────
# API 请求间隔（秒），防止频率限制
API_SLEEP_SECONDS=0.5
